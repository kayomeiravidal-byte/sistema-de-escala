# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# Segurança — gere uma nova chave para produção:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-in-production

# Em produção use False
DEBUG=True

# Hosts permitidos separados por vírgula
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens CSRF confiáveis separadas por vírgula
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Origens CORS permitidas separadas por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Banco de dados (SQLite padrão, substitua por postgres em produção)
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=

# Fuso horário
TIME_ZONE=America/Sao_Paulo
